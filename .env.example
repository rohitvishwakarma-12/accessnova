# ========================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# ========================================

# Application Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000
NODE_ENV=development
PORT=3000

# ========================================
# Google Generative AI Configuration
# ========================================
# Get your API key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# ========================================
# Email/SMTP Configuration (Nodemailer)
# ========================================
# Gmail: smtp.gmail.com (587)
# Hostinger (Titan): smtp.titan.email (587)
SMTP_HOST=smtp.titan.email
SMTP_PORT=587
SMTP_SECURE=false
EMAIL_USER=info@accessnovaa.com
EMAIL_PASS=your-email-password-here

# Email addresses
SMTP_FROM=info@accessnovaa.com
SMTP_FROM_NAME=AccessNova
RECIPIENT_EMAIL=info@accessnovaa.com

# ========================================
# Optional: Advanced Configuration
# ========================================
# Database (if using)
# DATABASE_URL=postgresql://user:password@localhost:5432/accessnova

# API Rate Limiting
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

# Security
# CORS_ENABLED=true
# CORS_ORIGIN=https://yourdomain.com
