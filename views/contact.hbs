<!-- CONTACT HERO -->
<section class="pt-36 pb-16 theme-gradient-bg relative overflow-hidden">
  <div class="absolute inset-0 opacity-20">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-purple-300 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-pink-300 rounded-full blur-3xl"></div>
  </div>
  <div class="container mx-auto px-6 relative z-10 text-center">
    <p class="text-xs font-bold text-purple-200 uppercase tracking-widest mb-3">Get In Touch</p>
    <h1 class="text-4xl md:text-6xl font-bold text-white mb-4">Contact <span class="text-pink-200">AccessNovaa</span></h1>
    <p class="text-purple-100/80 text-lg max-w-xl mx-auto">Fill out the form below and our team will respond within 24 hours</p>
  </div>
</section>

<!-- CONTACT FORM + INFO -->
<section class="py-20 bg-slate-50">
  <div class="container mx-auto px-6">
    <div class="max-w-6xl mx-auto bg-white rounded-3xl shadow-2xl overflow-hidden flex flex-col lg:flex-row border border-slate-100">

      <!-- Form Side -->
      <div class="w-full lg:w-3/5 p-10 md:p-14">
        <h2 class="text-2xl md:text-3xl font-bold navy-text mb-2">Send Us a <span class="theme-gradient-text">Message</span></h2>
        <p class="text-slate-400 mb-8 text-sm">We usually respond within a few hours on business days</p>

        {{#if success}}
        <div class="p-5 mb-8 bg-green-50 border border-green-200 text-green-700 rounded-xl flex items-start gap-3">
          <svg class="w-5 h-5 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          <div>
            <p class="font-semibold">Message Sent Successfully!</p>
            <p class="text-sm mt-1">{{success}} A confirmation email has been sent to your inbox.</p>
          </div>
        </div>
        {{/if}}

        {{#if error}}
        <div class="p-5 mb-8 bg-red-50 border border-red-200 text-red-700 rounded-xl flex items-start gap-3">
          <svg class="w-5 h-5 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
          <div>
            <p class="font-semibold">Something went wrong</p>
            <p class="text-sm mt-1">{{error}}</p>
          </div>
        </div>
        {{/if}}

        <form action="/contact" method="POST" class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div>
              <label for="name" class="block text-sm font-semibold text-slate-700 mb-2">Full Name <span class="text-pink-500">*</span></label>
              <input type="text" id="name" name="name" required placeholder="John Doe"
                class="w-full px-4 py-3.5 rounded-xl border border-slate-200 focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none transition-all text-sm bg-slate-50 focus:bg-white">
            </div>
            <div>
              <label for="email" class="block text-sm font-semibold text-slate-700 mb-2">Email Address <span class="text-pink-500">*</span></label>
              <input type="email" id="email" name="email" required placeholder="john@company.com"
                class="w-full px-4 py-3.5 rounded-xl border border-slate-200 focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none transition-all text-sm bg-slate-50 focus:bg-white">
            </div>
          </div>
          <div>
            <label for="subject" class="block text-sm font-semibold text-slate-700 mb-2">Subject <span class="text-pink-500">*</span></label>
            <input type="text" id="subject" name="subject" required placeholder="How can we help you?"
              class="w-full px-4 py-3.5 rounded-xl border border-slate-200 focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none transition-all text-sm bg-slate-50 focus:bg-white">
          </div>
          <div>
            <label for="message" class="block text-sm font-semibold text-slate-700 mb-2">Your Message <span class="text-pink-500">*</span></label>
            <textarea id="message" name="message" rows="5" required placeholder="Tell us about your project, document type, and accessibility requirements..."
              class="w-full px-4 py-3.5 rounded-xl border border-slate-200 focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none transition-all text-sm bg-slate-50 focus:bg-white resize-none"></textarea>
          </div>
          <button type="submit"
            class="w-full sm:w-auto px-10 py-4 theme-gradient-bg text-white font-bold rounded-xl transition-all transform hover:scale-[1.02] shadow-lg shadow-purple-600/25 text-sm flex items-center gap-2 justify-center">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
            Send Message
          </button>
        </form>
      </div>

      <!-- Info Side -->
      <div class="w-full lg:w-2/5 theme-gradient-bg p-10 md:p-14 text-white flex flex-col justify-between">
        <div>
          <h3 class="text-2xl font-bold mb-8">Contact Information</h3>
          <div class="space-y-7">
            <div class="flex items-start gap-4">
              <div class="w-11 h-11 bg-white/15 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              </div>
              <div>
                <p class="text-xs text-purple-200 font-bold uppercase tracking-wider mb-1">Call / WhatsApp</p>
                <a href="tel:+917982171047" class="font-semibold hover:text-pink-200 transition-colors">+91 79821 71047</a>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-11 h-11 bg-white/15 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </div>
              <div>
                <p class="text-xs text-purple-200 font-bold uppercase tracking-wider mb-1">Email</p>
                <a href="mailto:info@accessnovaa.com" class="font-semibold hover:text-pink-200 transition-colors">info@accessnovaa.com</a>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-11 h-11 bg-white/15 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 2m6 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <div>
                <p class="text-xs text-purple-200 font-bold uppercase tracking-wider mb-1">Business Hours</p>
                <p class="font-semibold">Mon–Sat, 9AM – 8PM IST</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Quick links -->
        <div class="mt-12 pt-10 border-t border-white/15">
          <h4 class="font-bold mb-5 text-sm uppercase tracking-wider text-purple-200">Quick Connect</h4>
          <a href="https://wa.me/917982171047?text=Hi%20AccessNovaa%2C%20I%27d%20like%20to%20inquire%20about%20your%20services." target="_blank"
            class="flex items-center gap-3 bg-green-500/20 border border-green-400/30 hover:bg-green-500/30 text-white font-semibold py-3 px-5 rounded-xl transition-all text-sm mb-3">
            <svg class="w-5 h-5 text-green-300" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Chat on WhatsApp
          </a>
          <div class="mt-6 p-4 bg-white/10 rounded-xl">
            <p class="text-xs text-purple-200 font-semibold uppercase tracking-wider mb-2">Why contact us?</p>
            <p class="text-sm text-purple-100/80 leading-relaxed">Get comprehensive accessibility audits, expert remediation services, and enterprise training tailored to your needs</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
