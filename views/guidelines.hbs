<!-- GUIDELINES HERO -->
<section class="pt-36 pb-16 theme-gradient-bg relative overflow-hidden">
  <div class="absolute inset-0 opacity-20">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-purple-300 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-pink-300 rounded-full blur-3xl"></div>
  </div>
  <div class="container mx-auto px-6 relative z-10 text-center">
    <p class="text-xs font-bold text-purple-200 uppercase tracking-widest mb-3">Standards We Follow</p>
    <h1 class="text-4xl md:text-6xl font-bold text-white mb-4">Accessibility <span class="text-pink-200">Guidelines</span></h1>
    <p class="text-purple-100/80 text-lg max-w-2xl mx-auto">We adhere to the highest global standards to ensure your digital content is accessible, inclusive, and legally compliant</p>
  </div>
