  <style>
    *{box-sizing:border-box;}
    html{overflow-x:hidden;scroll-behavior:smooth;}
    body{font-family:'Inter',sans-serif;background:#ffffff;color:#0f172a;overflow-x:hidden;}
    h1,h2,h3,h4,.font-heading{font-family:'Outfit',sans-serif;}
    .theme-gradient-bg{background:linear-gradient(135deg,#6b21a8 0%,#db2777 100%);}
    .theme-gradient-text{background:linear-gradient(135deg,#6b21a8 0%,#db2777 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
    .navy-bg{background-color:#050110;}
    .navy-text{color:#1e1b4b;}
    .accent-purple{color:#7e22ce;}
    .accent-pink{color:#db2777;}

    /* NAV */
    .glass-nav{background:rgba(10,1,24,0.4);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);transition:all 0.4s cubic-bezier(0.4,0,0.2,1);border:1px solid rgba(255,255,255,0.1);border-radius:9999px;margin-top:1.5rem;width:95%;max-width:1200px;}
    .glass-nav.scrolled{background:rgba(10,1,24,0.92);margin-top:0.5rem;box-shadow:0 10px 40px -10px rgba(0,0,0,0.6);}
    .nav-link{color:rgba(203,213,225,0.9);font-size:0.875rem;font-weight:500;padding:6px 4px;border-bottom:2px solid transparent;transition:all 0.2s;}
    .nav-link:hover,.nav-link.active{color:#fff;border-bottom-color:#db2777;}
    .dot-pattern{width:120px;height:64px;background-image:radial-gradient(currentColor 2px,transparent 2px);background-size:16px 16px;}
    
    /* LOGO STYLING */
    .logo-container{display:flex;align-items:center;gap:0.6rem;flex-shrink:0;text-decoration:none;}
    .logo-img{height:46px;width:auto;object-fit:contain;display:block;filter:drop-shadow(0 0 8px rgba(219,39,119,0.35));transition:opacity 0.3s ease,transform 0.3s ease,filter 0.3s ease;}
    .logo-img:hover{transform:scale(1.04);filter:drop-shadow(0 0 12px rgba(219,39,119,0.6));}
    .logo-text{font-family:'Outfit',sans-serif;font-size:1.15rem;font-weight:800;background:linear-gradient(135deg,#a855f7 0%,#ec4899 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;white-space:nowrap;letter-spacing:-0.01em;}
    @media(max-width:640px){.logo-img{height:38px;} .logo-text{font-size:1rem;}}

    /* CARDS */
    .card-hover{transition:transform 0.3s ease,box-shadow 0.3s ease;}
    .card-hover:hover{transform:translateY(-6px);box-shadow:0 20px 40px rgba(107,33,168,0.12);}

    /* ANIMATIONS */
    @keyframes fadeInUp{from{opacity:0;transform:translateY(30px);}to{opacity:1;transform:translateY(0);}}
    @keyframes fadeInLeft{from{opacity:0;transform:translateX(-30px);}to{opacity:1;transform:translateX(0);}}
    @keyframes fadeInRight{from{opacity:0;transform:translateX(30px);}to{opacity:1;transform:translateX(0);}}
    @keyframes scaleIn{from{opacity:0;transform:scale(0.92);}to{opacity:1;transform:scale(1);}}
    .animate-fade-in{animation:fadeInUp 0.7s ease-out forwards;}
    .animate-left{animation:fadeInLeft 0.7s ease-out forwards;}
    .animate-right{animation:fadeInRight 0.7s ease-out forwards;}
    .animate-scale{animation:scaleIn 0.6s ease-out forwards;}
    .anim-delay-1{animation-delay:0.1s;}
    .anim-delay-2{animation-delay:0.2s;}
    .anim-delay-3{animation-delay:0.3s;}
    .anim-delay-4{animation-delay:0.4s;}
    [data-aos]{opacity:0;}
    [data-aos].aos-visible{opacity:1;}

    /* WHATSAPP */
    .whatsapp-float{position:fixed!important;bottom:30px;right:30px!important;left:auto!important;width:58px;height:58px;background:linear-gradient(135deg,#25d366 0%,#128c7e 100%);color:#fff;border-radius:50%;text-align:center;box-shadow:0 4px 20px rgba(37,211,102,0.4);z-index:9999;display:flex;align-items:center;justify-content:center;transition:transform 0.3s ease,box-shadow 0.3s ease;}
    .whatsapp-float:hover{transform:scale(1.12) translateY(-4px);box-shadow:0 8px 30px rgba(37,211,102,0.6);color:#fff;}
    .whatsapp-float .tooltip{visibility:hidden;width:180px;background:#1e1b4b;color:#fff;text-align:center;border-radius:8px;padding:8px 12px;position:absolute;z-index:1;bottom:calc(100% + 10px);right:0;opacity:0;transition:opacity 0.3s;font-size:13px;pointer-events:none;white-space:nowrap;}
    .whatsapp-float:hover .tooltip{visibility:visible;opacity:1;}

    /* CHAT FLOAT */
    .chat-float{position:fixed!important;bottom:30px;left:30px!important;right:auto!important;z-index:9999;width:58px;height:58px;border-radius:50%;background:linear-gradient(135deg,#6b21a8 0%,#db2777 100%);display:flex;align-items:center;justify-content:center;cursor:pointer;color:white;box-shadow:0 4px 20px rgba(107,33,168,0.4);transition:all 0.3s cubic-bezier(0.175,0.885,0.32,1.275);}
    .chat-float:hover{transform:scale(1.1) translateY(-4px);box-shadow:0 8px 30px rgba(219,39,119,0.5);}
    .chat-float .tooltip{visibility:hidden;width:140px;background:#1e1b4b;color:#fff;text-align:center;border-radius:8px;padding:8px 12px;position:absolute;z-index:1;left:calc(100% + 12px);top:50%;transform:translateY(-50%);opacity:0;transition:opacity 0.3s;font-size:13px;pointer-events:none;white-space:nowrap;}
    .chat-float:hover .tooltip{visibility:visible;opacity:1;}
    @keyframes pulse-ring{0%{transform:scale(1);opacity:0.6;}100%{transform:scale(1.8);opacity:0;}}
    .pulse-ring{position:absolute;width:100%;height:100%;border-radius:50%;border:2px solid currentColor;animation:pulse-ring 2s ease-out infinite;}

    /* CHAT POPUP */
    .chat-popup{position:fixed!important;bottom:100px;left:30px!important;right:auto!important;width:370px;height:540px;background:#fff;border-radius:20px;box-shadow:0 16px 50px rgba(0,0,0,0.18);display:flex;flex-direction:column;z-index:9998;overflow:hidden;border:1px solid rgba(0,0,0,0.06);}
    @keyframes slideUpLeft{from{opacity:0;transform:translateY(30px) scale(0.95);}to{opacity:1;transform:translateY(0) scale(1);}}
    .chat-popup.open{animation:slideUpLeft 0.35s cubic-bezier(0.165,0.84,0.44,1) forwards;}
    .chat-header{background:linear-gradient(135deg,#6b21a8 0%,#db2777 100%);color:white;padding:16px 20px;display:flex;justify-content:space-between;align-items:center;}
    .chat-status{display:flex;align-items:center;gap:6px;font-size:11px;font-weight:400;opacity:0.9;margin-top:2px;}
    .chat-header button{background:rgba(255,255,255,0.15);border:none;color:white;width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:background 0.2s;font-size:14px;}
    .chat-header button:hover{background:rgba(255,255,255,0.25);}
    .chat-body{flex:1;overflow-y:auto;padding:14px;display:flex;flex-direction:column;gap:10px;}
    .chat-msg{max-width:82%;padding:10px 14px;border-radius:14px;font-size:13px;line-height:1.6;white-space:pre-wrap;}
    .chat-msg.bot{background:#f1f5f9;color:#1e293b;align-self:flex-start;border-bottom-left-radius:4px;}
    .chat-msg.user{background:linear-gradient(135deg,#6b21a8 0%,#db2777 100%);color:white;align-self:flex-end;border-bottom-right-radius:4px;}
    .quick-starts{padding:8px 14px;display:flex;flex-wrap:wrap;gap:6px;}
    .qs-btn{background:#f8fafc;border:1px solid #e2e8f0;padding:5px 12px;border-radius:16px;font-size:12px;color:#64748b;cursor:pointer;transition:all 0.2s;}
    .qs-btn:hover{background:#ede9fe;border-color:#7c3aed;color:#6b21a8;}
    .typing-indicator{padding:10px 16px;display:flex;gap:4px;align-items:center;}
    .typing-indicator span{width:8px;height:8px;background:#7c3aed;border-radius:50%;animation:bounce 1.2s infinite;}
    .typing-indicator span:nth-child(2){animation-delay:0.2s;}
    .typing-indicator span:nth-child(3){animation-delay:0.4s;}
    @keyframes bounce{0%,80%,100%{transform:translateY(0);}40%{transform:translateY(-8px);}}
    .chat-footer{display:flex;padding:10px;border-top:1px solid #f1f5f9;gap:8px;}
    .chat-footer input{flex:1;padding:9px 14px;border:1px solid #e2e8f0;border-radius:20px;font-size:13px;outline:none;transition:border-color 0.2s;}
    .chat-footer input:focus{border-color:#7c3aed;}
    .chat-footer button{background:linear-gradient(135deg,#6b21a8,#db2777);color:white;border:none;padding:9px 18px;border-radius:20px;cursor:pointer;font-size:13px;font-weight:600;transition:opacity 0.2s;}
    .chat-footer button:hover{opacity:0.9;}
    .chat-powered{text-align:center;font-size:11px;color:#cbd5e1;padding:4px 0 8px;}

    /* SWIPER CUSTOM */
    .swiper-pagination-bullet{background:#7c3aed!important;}
    .swiper-pagination-bullet-active{background:#db2777!important;}
    .swiper-button-next,.swiper-button-prev{color:#7c3aed!important;}

    @media(max-width:480px){
      .chat-popup{width:calc(100vw - 20px);left:10px;bottom:96px;}
      .chat-float{bottom:25px;left:20px;}
      .whatsapp-float{bottom:25px;right:20px;}
    }
  </style>
</head>
