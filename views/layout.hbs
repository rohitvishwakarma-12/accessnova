  <!-- AI Chatbot Button -->
  <div class="chat-float" onclick="toggleChat()" role="button" aria-label="Open AI Chat">
    <span class="pulse-ring text-purple-400"></span>
    <svg class="w-7 h-7 relative z-10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
